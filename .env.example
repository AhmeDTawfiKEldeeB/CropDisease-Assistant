# ======================== Qdrant Config ========================

QDRANT__URL="https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io:6333"
QDRANT__API_KEY="your-qdrant-api-key"
QDRANT__COLLECTION_NAME="plant_diseases_kb"
QDRANT__UPLOAD_BATCH_SIZE=64
QDRANT__DATA_JSON_PATH="chatbot/diseases_from_md_clean.json"

# ======================== HuggingFace Embedding Config ========================

HUGGINGFACE__MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
HUGGINGFACE__MODEL_DIMENSIONS=384

# ======================== CV / Plant Disease Model Config ========================

CV__MODEL_PATH="src/cv/models/resnet50_plant_38class_best.pth.zip"
CV__NUM_CLASSES=38
CV__IMAGE_SIZE=224
CV__ENTROPY_THRESHOLD=0.4
CV__GAP_THRESHOLD=5.0
# Lower temperature (<1.0) sharpens confidence scores. Try 0.55-0.7 if the
# model feels under-confident on clear leaf photos.
CV__TEMPERATURE=1.0
CV__TTA_ENABLED=false
CV__DEVICE="auto"
